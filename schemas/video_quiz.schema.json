{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/decoration-inspiration/schemas/video_quiz.schema.json",
  "title": "VideoQuiz",
  "type": "object",
  "additionalProperties": false,
  "required": ["questions"],
  "properties": {
    "questions": {
      "type": "array",
      "minItems": 5,
      "maxItems": 20,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["q", "options", "answer_idx", "explanation", "ts", "topic"],
        "properties": {
          "q": { "type": "string", "minLength": 1 },
          "options": {
            "type": "array",
            "minItems": 4,
            "maxItems": 4,
            "items": { "type": "string", "minLength": 1 }
          },
          "answer_idx": { "type": "integer", "minimum": 0, "maximum": 3 },
          "explanation": { "type": "string", "minLength": 1 },
          "ts": { "type": "number", "minimum": 0, "description": "对应视频时间戳（秒）" },
          "topic": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
