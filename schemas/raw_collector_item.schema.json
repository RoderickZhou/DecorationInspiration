{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/decoration-inspiration/schemas/raw_collector_item.schema.json",
  "title": "RawCollectorItem",
  "type": "object",
  "additionalProperties": true,
  "required": ["platform", "canonical_url", "fetched_at"],
  "properties": {
    "platform": { "type": "string", "minLength": 1 },
    "canonical_url": { "type": "string", "minLength": 1 },
    "fetched_at": { "type": "string", "minLength": 1 },
    "title": { "type": "string" },
    "author": { "type": "string" },
    "published_at": { "type": "string" },
    "content_text": { "type": "string" },
    "images": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["url"],
        "properties": {
          "url": { "type": "string", "minLength": 1 },
          "width": { "type": "integer", "minimum": 0 },
          "height": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "likes": { "type": "integer", "minimum": 0 },
        "favorites": { "type": "integer", "minimum": 0 },
        "comments": { "type": "integer", "minimum": 0 }
      }
    },
    "raw": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "html": { "type": "string" },
        "json": {}
      }
    }
  }
}

