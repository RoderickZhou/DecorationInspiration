{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/decoration-inspiration/schemas/minimax_daily_summary.schema.json",
  "title": "MinimaxDailySummaryIO",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "task", "user_profile_snapshot", "items"],
  "properties": {
    "schema_version": { "type": "string", "enum": ["v1"] },
    "task": { "type": "string", "enum": ["daily_summary"] },
    "user_profile_snapshot": { "type": "object" },
    "items": { "type": "array", "items": { "type": "object" } },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["today_focus", "summary", "daily_digest"],
      "properties": {
        "today_focus": { "type": "array", "minItems": 1, "maxItems": 3, "items": { "type": "string", "minLength": 1 } },
        "summary": {
          "type": "object",
          "additionalProperties": false,
          "required": ["headline", "highlights", "question_of_the_day", "fit_direction"],
          "properties": {
            "headline": { "type": "string", "minLength": 1 },
            "highlights": { "type": "array", "minItems": 1, "maxItems": 3, "items": { "type": "string", "minLength": 1 } },
            "question_of_the_day": { "type": "string", "minLength": 1 },
            "fit_direction": { "type": "array", "minItems": 1, "maxItems": 3, "items": { "type": "string", "minLength": 1 } }
          }
        },
        "daily_digest": {
          "type": "object",
          "additionalProperties": false,
          "required": ["estimated_read_minutes", "recommended_browse_order", "top_tags"],
          "properties": {
            "estimated_read_minutes": { "type": "integer", "minimum": 1, "maximum": 15 },
            "recommended_browse_order": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
            "top_tags": { "type": "array", "minItems": 1, "maxItems": 6, "items": { "type": "string", "minLength": 1 } }
          }
        }
      }
    }
  }
}

