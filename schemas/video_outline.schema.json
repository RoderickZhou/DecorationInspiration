{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/decoration-inspiration/schemas/video_outline.schema.json",
  "title": "VideoOutline",
  "type": "object",
  "additionalProperties": false,
  "required": ["chapters"],
  "properties": {
    "chapters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ts", "title", "key_points"],
        "properties": {
          "ts": { "type": "number", "minimum": 0, "description": "起始秒数" },
          "title": { "type": "string", "minLength": 1 },
          "key_points": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
